rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isVendor() {
      return hasRole('vendor');
    }

    function isDeliveryPersonnel() {
      return hasRole('delivery_personnel');
    }

    function isSecurity() {
      return hasRole('security');
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Family members collection
    match /family_members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (isOwner(resource.data.parentId) || isAdmin() || isSecurity());
      allow delete: if isAuthenticated() &&
        (isOwner(resource.data.parentId) || isAdmin());
    }

    // QR tags collection
    match /qr_tags/{tagId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Incidents collection
    match /incidents/{incidentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (isOwner(resource.data.reportedBy) || isAdmin() || isSecurity());
      allow delete: if isAdmin();
    }

    // Signals collection
    match /signals/{signalId} {
      allow read: if isAdmin() || isSecurity();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isSecurity();
      allow delete: if isAdmin();
    }

    // Vendors collection
    match /vendors/{vendorId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (isOwner(resource.data.userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Products collection
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isVendor();
      allow update: if isAuthenticated() &&
        (isOwner(resource.data.vendorId) || isAdmin());
      allow delete: if isAuthenticated() &&
        (isOwner(resource.data.vendorId) || isAdmin());
    }

    // Orders collection
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (isOwner(resource.data.userId) || isAdmin() || isDeliveryPersonnel());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (isOwner(resource.data.userId) || isAdmin() || isDeliveryPersonnel());
      allow delete: if isAdmin();
    }

    // Deliveries collection
    match /deliveries/{deliveryId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAuthenticated() &&
        (isOwner(resource.data.deliveryPersonnelId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if isAuthenticated() &&
        (isOwner(resource.data.userId) || isAdmin());
    }

    // ── Messages (real-time channels) ─────────────────────────────
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (request.auth.uid == resource.data.senderId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Broadcasts (admin announcements) ──────────────────────────
    match /broadcasts/{broadcastId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || isSecurity());
      allow update: if isAuthenticated() && (isAdmin() || isSecurity());
      allow delete: if isAdmin();
    }

    // ── User Locations (real-time crowd density) ──────────────────
    // Attendees opt-in to share their GPS for crowd analysis
    match /user_locations/{userId} {
      allow read: if isAuthenticated() && (isAdmin() || isSecurity());
      allow write: if isOwner(userId); // only you can update your own location
      allow delete: if isOwner(userId) || isAdmin();
    }

  }
}
