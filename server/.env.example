# ─────────────────────────────────────────────────────────────────
# Redemption OS Backend — Environment Variables Template
# Copy this file to '.env' and fill in your values
# ─────────────────────────────────────────────────────────────────

# Port to run the server on
PORT=5001

# Termii SMS API Integration
# Get your api key from: https://termii.com
TERMII_API_KEY=your_termii_api_key_here
TERMII_SENDER_ID=Redemption

# Africa's Talking SMS/USSD API Integration
# Get your credentials from: https://africastalking.com
AT_API_KEY=your_africas_talking_api_key_here
AT_USERNAME=sandbox # Use 'sandbox' for testing, or your production username

# Default responder phone number (International format: e.g. +2348000000000)
DEFAULT_RESPONDER_PHONE=+2348001112233
